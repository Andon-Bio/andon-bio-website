---
// HOME Beat 1 — cause. Headline left, body right.
const statement = "You can't fix what you can't see.";
const body =
  "A cell only makes protein as fast as it can supply the parts the design calls for. Push it to overproduce, and demand outruns supply in ways that depend on the sequence — and that supply has been invisible. So when a protein underperforms, there's no signal to act on. You change something, run it again, and hope.";
---

<section class="px-6 py-20 md:px-10 md:py-28">
  <div
    class="mx-auto grid max-w-[72rem] gap-10 md:grid-cols-[1.3fr_1fr] md:gap-16"
  >
    <h2
      class="rise text-balance font-display text-3xl font-bold leading-[1.1] tracking-[-0.02em] text-ink md:text-[2.75rem]"
    >
      {statement}
    </h2>
    <p
      class="rise self-end text-lg leading-[1.7] text-muted"
      style="animation-delay: 100ms"
    >
      {body}
    </p>
  </div>
</section>
