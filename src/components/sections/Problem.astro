---
const statement = "Most protein expression optimization still runs on trial and error.";
const body =
  "Teams iterate blind because the supply and demand of translational resources has never been visible. Andon adds the measurement layer that's been missing — turning guesswork about translation into direct molecular data.";
---

<section class="px-6 py-20 md:px-10 md:py-28">
  <div
    class="mx-auto grid max-w-[72rem] gap-10 md:grid-cols-[1.3fr_1fr] md:gap-16"
  >
    <h2
      class="rise text-balance font-display text-3xl font-bold leading-[1.1] tracking-[-0.02em] text-ink md:text-[2.75rem]"
    >
      {statement}
    </h2>
    <p
      class="rise self-end text-lg leading-[1.7] text-muted"
      style="animation-delay: 100ms"
    >
      {body}
    </p>
  </div>
</section>
