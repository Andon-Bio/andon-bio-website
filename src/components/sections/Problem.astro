---
// HOME Beat 1 — cause. Heading over body, left on the shared rail.
const statement = "You can't fix what you can't see.";
const body =
  "A cell makes protein only as fast as it can supply the parts the design calls for. Push it to overproduce, and demand outruns supply, differently for every sequence. So when a protein underperforms, there's no signal to act on. You change something, run it again, and hope.";
---

<section class="px-6 py-8 md:px-10 md:py-12">
  <div class="mx-auto max-w-[72rem]">
    <h2
      class="rise max-w-[42rem] text-balance font-display text-3xl font-bold leading-[1.1] tracking-[-0.02em] text-ink md:text-[2.5rem]"
    >
      {statement}
    </h2>
    <p
      class="rise mt-6 max-w-[46rem] text-lg leading-[1.75] text-muted"
      style="animation-delay: 100ms"
    >
      {body}
    </p>
  </div>
</section>
