---
const statement = "Every new sequence is a blind bet on whether the cell can build it.";
const body =
  "Design tools spin up new proteins in an afternoon, but none can tell you whether a given sequence will express in a given system. So the same blind bet gets placed over and over — with no way to see why one construct works and the next stalls. The reason it's unpredictable: the cellular supply chain that governs expression has been invisible during production.";
---

<section class="px-6 py-20 md:px-10 md:py-28">
  <div
    class="mx-auto grid max-w-[72rem] gap-10 md:grid-cols-[1.3fr_1fr] md:gap-16"
  >
    <h2
      class="rise text-balance font-display text-3xl font-bold leading-[1.1] tracking-[-0.02em] text-ink md:text-[2.75rem]"
    >
      {statement}
    </h2>
    <p
      class="rise self-end text-lg leading-[1.7] text-muted"
      style="animation-delay: 100ms"
    >
      {body}
    </p>
  </div>
</section>
