---
import { SITE } from "../../site";

const ARROW = `<path d="M7 7h10v10"/><path d="M7 17 17 7"/>`;

const STEPS = [
  {
    icon: `<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>`,
    title: "Measure",
    description:
      "We read charged tRNAs directly with nanopore aa-tRNA-seq, the single-molecule method co-invented at CU Anschutz — present tense, today.",
  },
  {
    icon: `<path d="M3 7V5a2 2 0 0 1 2-2h2"/><path d="M17 3h2a2 2 0 0 1 2 2v2"/><path d="M21 17v2a2 2 0 0 1-2 2h-2"/><path d="M7 21H5a2 2 0 0 1-2-2v-2"/><circle cx="12" cy="12" r="3"/><path d="m16 16-1.9-1.9"/>`,
    title: "Reveal",
    description:
      "Charging state, measured genome-wide, shows where tRNA supply falls short of codon demand during production.",
  },
  {
    icon: `<path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/><path d="M20 3v4"/><path d="M22 5h-4"/><path d="M4 17v2"/><path d="M5 18H3"/>`,
    title: "Predict",
    description:
      "Where we're headed: as this measurement scales across systems, it becomes the foundation for predicting whether — and how well — a sequence will express.",
  },
];
---

<section
  id="how"
  class="scroll-mt-20 bg-navy px-6 py-20 text-paper md:px-10 md:py-28"
>
  <div
    class="mx-auto grid max-w-[78rem] gap-12 lg:grid-cols-[0.85fr_1.15fr] lg:gap-20"
  >
    <div class="lg:sticky lg:top-28 lg:self-start">
      <h2
        class="rise text-balance font-display text-3xl font-bold leading-[1.1] tracking-[-0.02em] md:text-[2.75rem]"
      >
        From measurement to prediction
      </h2>
      <p
        class="rise mt-5 max-w-[28rem] text-lg leading-[1.7] text-paper-muted"
        style="animation-delay: 100ms"
      >
        Andon makes a molecular signal nobody could see measurable — the first
        step toward predicting expression instead of guessing at it.
      </p>
      <a
        href={`mailto:${SITE.email}`}
        class="rise mt-8 inline-flex items-center gap-2 font-button text-sm tracking-wide text-accent transition-colors hover:text-accent-400"
        style="animation-delay: 180ms"
      >
        Let's talk
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={ARROW} />
      </a>
    </div>

    <div class="flex flex-col">
      {
        STEPS.map((step, i) => (
          <div
            class="rise group flex items-start gap-5 border-t border-line-dark py-7 first:border-t-0 first:pt-0"
            style={`animation-delay: ${i * 70}ms`}
          >
            <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl border border-line-dark bg-navy-soft text-accent">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={step.icon} />
            </span>
            <div class="flex-1">
              <h3 class="font-display text-lg font-bold tracking-tight md:text-xl">
                {step.title}
              </h3>
              <p class="mt-1.5 max-w-[34rem] text-[0.95rem] leading-[1.6] text-paper-muted">
                {step.description}
              </p>
            </div>
            <span class="mt-1 flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-line-dark text-paper-muted transition-colors group-hover:border-accent group-hover:text-accent">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={ARROW} />
            </span>
          </div>
        ))
      }
    </div>
  </div>
</section>
