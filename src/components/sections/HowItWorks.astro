---
import { SITE } from "../../site";

const features = [
  {
    title: "Measure tRNA charging",
    desc: "We read charged tRNAs directly with nanopore aa-tRNA-seq, the single-molecule method co-invented at CU Anschutz.",
    icon: `<path d="M3 12h4l2 6 4-12 2 6h6"/>`,
  },
  {
    title: "Reveal the bottlenecks",
    desc: "Charging data exposes where tRNA supply fails to meet codon demand — the precise limits on protein output.",
    icon: `<circle cx="12" cy="12" r="3"/><path d="M3 7V5a2 2 0 0 1 2-2h2"/><path d="M17 3h2a2 2 0 0 1 2 2v2"/><path d="M21 17v2a2 2 0 0 1-2 2h-2"/><path d="M7 21H5a2 2 0 0 1-2-2v-2"/>`,
  },
  {
    title: "Predict better sequences",
    desc: "Those measurements train a predictive engine that designs sequences for higher, more reliable expression.",
    icon: `<path d="M5 3v4"/><path d="M3 5h4"/><path d="M6 17v4"/><path d="M4 19h4"/><path d="M13 4l1.8 5.2L20 11l-5.2 1.8L13 18l-1.8-5.2L6 11l5.2-1.8z"/>`,
  },
  {
    title: "Raise yield, cut cycles",
    desc: "Protein engineers replace guesswork with real signal — lifting yield and avoiding costly development loops.",
    icon: `<polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/>`,
  },
];
---

<section id="how-it-works" class="scroll-mt-20 bg-navy">
  <div class="mx-auto grid max-w-6xl gap-12 px-6 py-24 lg:grid-cols-[0.85fr_1.15fr] lg:gap-20">
    <!-- intro -->
    <div class="lg:sticky lg:top-28 lg:self-start">
      <h2 class="font-display text-4xl font-bold leading-tight text-paper md:text-5xl">
        From measurement to prediction
      </h2>
      <p class="mt-5 text-lg leading-relaxed text-paper-muted">
        Andon turns a molecular signal nobody could see into a workflow protein
        teams can act on.
      </p>
      <a
        href={`mailto:${SITE.email}`}
        class="mt-7 inline-flex items-center gap-1.5 font-mono text-sm text-accent-bright hover:underline"
      >
        Get early access
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
      </a>
    </div>

    <!-- features -->
    <div class="flex flex-col divide-y divide-line-dark">
      {
        features.map((f) => (
          <a
            href="/science"
            class="group flex gap-4 py-6 first:pt-0 last:pb-0"
          >
            <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-navy-soft text-accent-bright">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={f.icon} />
            </span>
            <div class="flex-1">
              <div class="flex items-start justify-between gap-3">
                <h3 class="font-display text-lg font-semibold text-paper">
                  {f.title}
                </h3>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-1 shrink-0 text-paper-muted/60 transition-colors group-hover:text-accent-bright" aria-hidden="true"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
              </div>
              <p class="mt-1.5 text-sm leading-relaxed text-paper-muted">
                {f.desc}
              </p>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
