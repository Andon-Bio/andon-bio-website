---
import { SITE } from "../../site";
import Button from "../Button.astro";

interface Props {
  heading?: string;
  body?: string;
}

const {
  heading = "See what's actually happening in your system",
  body = "If you express a lot of protein, the charged-tRNA supply behind it has never been visible. We'd like to show you what we'd see in yours — let's talk.",
} = Astro.props;
---

<section class="px-6 py-24 text-center md:px-10 md:py-32">
  <div class="rise mx-auto max-w-[42rem]">
    <h2
      class="text-balance font-display text-3xl font-bold leading-[1.1] tracking-[-0.02em] text-ink md:text-5xl"
    >
      {heading}
    </h2>
    <p class="mx-auto mt-5 max-w-[34rem] text-lg leading-[1.7] text-muted">
      {body}
    </p>
    <div class="mt-9 flex flex-col items-center gap-4">
      <Button href={`mailto:${SITE.email}`} size="lg">Let's talk</Button>
      <a
        href={`mailto:${SITE.email}`}
        class="font-button text-sm tracking-wide text-accent-700 transition-colors hover:text-accent-800"
      >
        {SITE.email}
      </a>
    </div>
  </div>
</section>
