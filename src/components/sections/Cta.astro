---
import { SITE } from "../../site";
import Button from "../Button.astro";

interface Props {
  heading?: string;
  body?: string;
  cta?: string;
  tone?: "light" | "dark";
}

const {
  heading = "See what's actually happening inside your system.",
  body = "",
  cta = "Let's take a look",
  tone = "light",
} = Astro.props;

const dark = tone === "dark";
---

<section
  class:list={[
    "px-6 text-center md:px-10",
    dark
      ? "bg-navy text-paper pt-12 pb-10 md:pt-16 md:pb-12"
      : "py-12 md:py-16",
  ]}
>
  <div class="rise mx-auto max-w-[48rem]">
    <h2
      class:list={[
        "text-balance font-display text-3xl font-bold leading-[1.1] tracking-[-0.02em] md:text-5xl",
        dark ? "text-paper" : "text-ink",
      ]}
    >
      {heading}
    </h2>
    {
      body && (
        <p
          class:list={[
            "mx-auto mt-5 max-w-[34rem] text-lg leading-[1.7]",
            dark ? "text-paper-muted" : "text-muted",
          ]}
        >
          {body}
        </p>
      )
    }
    <div class="mt-9 flex flex-col items-center gap-4">
      <Button
        href={`mailto:${SITE.email}`}
        variant={dark ? "amber" : "primary"}
        size="lg"
      >
        {cta}
      </Button>
    </div>
  </div>
</section>
