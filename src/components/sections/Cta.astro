---
import { SITE } from "../../site";
import Button from "../Button.astro";

interface Props {
  heading?: string;
  body?: string;
  cta?: string;
  tone?: "light" | "dark";
}

const {
  heading = "See what's actually happening inside your system.",
  body = "Every protein makes its own demands on your cells' supply chain. That's never been visible.",
  cta = "Let's take a look",
  tone = "light",
} = Astro.props;

const dark = tone === "dark";
---

<section
  class:list={[
    "px-6 py-24 text-center md:px-10 md:py-32",
    dark ? "bg-navy text-paper" : "",
  ]}
>
  <div class="rise mx-auto max-w-[42rem]">
    <h2
      class:list={[
        "text-balance font-display text-3xl font-bold leading-[1.1] tracking-[-0.02em] md:text-5xl",
        dark ? "text-paper" : "text-ink",
      ]}
    >
      {heading}
    </h2>
    <p
      class:list={[
        "mx-auto mt-5 max-w-[34rem] text-lg leading-[1.7]",
        dark ? "text-paper-muted" : "text-muted",
      ]}
    >
      {body}
    </p>
    <div class="mt-9 flex flex-col items-center gap-4">
      <Button
        href={`mailto:${SITE.email}`}
        variant={dark ? "amber" : "primary"}
        size="lg"
      >
        {cta}
      </Button>
      <a
        href={`mailto:${SITE.email}`}
        class:list={[
          "font-button text-sm tracking-wide transition-colors",
          dark
            ? "text-accent hover:text-accent-400"
            : "text-accent-700 hover:text-accent-800",
        ]}
      >
        {SITE.email}
      </a>
    </div>
  </div>
</section>
