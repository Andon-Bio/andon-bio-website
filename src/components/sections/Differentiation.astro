---
// Deck slide 7 — the moat. Others measure consequences or upstream sequence;
// none measure supply itself during production. Present tense: this is what is
// (and isn't) measurable today.
const OTHERS = [
  {
    kicker: "Consequences",
    title: "Ribosome occupancy, protein yield",
    body: "Read out the downstream effects of a supply problem after it has already happened — they show that something went wrong, not why.",
  },
  {
    kicker: "Upstream sequence",
    title: "Codon usage, adaptation indices",
    body: "Infer translational supply from the genome — a static proxy that can't see how the tRNA pool actually shifts under the load of production.",
  },
];

const ANDON = {
  kicker: "Supply itself",
  title: "The charged-tRNA pool, during production",
  body: "Andon measures the cellular supply state directly, in the cell, under load — the layer that has never been visible to any other method.",
};
---

<section class="px-6 py-20 md:px-10 md:py-28">
  <div class="mx-auto max-w-[72rem]">
    <h2
      class="rise max-w-[40rem] text-balance font-display text-3xl font-bold leading-[1.1] tracking-[-0.02em] text-ink md:text-[2.5rem]"
    >
      Everyone measures around the problem. We measure the supply itself.
    </h2>
    <p
      class="rise mt-5 max-w-[38rem] text-lg leading-[1.7] text-muted"
      style="animation-delay: 100ms"
    >
      Existing tools read the consequences of a supply shortfall, or the
      sequence upstream of it. None measure the charged-tRNA supply as it
      changes during production.
    </p>

    <div class="mt-12 grid gap-5 md:grid-cols-3">
      {
        OTHERS.map((o, i) => (
          <article
            class="rise rounded-2xl border border-line/70 bg-surface p-7"
            style={`animation-delay: ${120 + i * 60}ms`}
          >
            <span class="font-button text-xs uppercase tracking-[0.16em] text-faint">
              {o.kicker}
            </span>
            <h3 class="mt-3 font-display text-lg font-bold tracking-tight text-ink">
              {o.title}
            </h3>
            <p class="mt-3 text-[0.95rem] leading-[1.65] text-muted">{o.body}</p>
          </article>
        ))
      }
      <article
        class="rise rounded-2xl border border-accent/60 bg-accent/10 p-7"
        style="animation-delay: 240ms"
      >
        <span class="font-button text-xs uppercase tracking-[0.16em] text-accent-700">
          {ANDON.kicker}
        </span>
        <h3 class="mt-3 font-display text-lg font-bold tracking-tight text-ink">
          {ANDON.title}
        </h3>
        <p class="mt-3 text-[0.95rem] leading-[1.65] text-muted">{ANDON.body}</p>
      </article>
    </div>
  </div>
</section>
