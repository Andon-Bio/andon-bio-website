---
// HOME — the four beats (question / Problem / Measures / Vision) condensed into
// a 2x2 tile grid. Rectangular tiles, slightly rounded; scannable instead of a
// long scroll. The Vision tile drops its lead sentence for length.
// Voice: "tRNA" never appears on Home.
const ARROW = `<path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>`;

const TILES = [
  {
    title: "Designing a protein is cheap. Finding out if a cell can make it isn't.",
    body: "Sequences can be generated faster than any lab can test them, but each one still has to be built and validated at the bench.",
  },
  {
    title: "You can't fix what you can't see.",
    body: "A cell makes protein only as fast as it can supply the parts the design calls for. Push it to overproduce, and demand outruns supply, differently for every sequence.",
  },
  {
    title: "Andon measures the supply chain, while the cell is making protein.",
    body: "We read the cellular supply state directly, in the systems proteins are actually made in, from microbes to mammalian cells.",
  },
  {
    title: "Measurement now. Prediction next.",
    body: "Every protein measured sharpens the next prediction, letting us design for manufacturability from the start instead of discovering it through trial and error.",
  },
];
---

<section class="px-6 py-8 md:px-10 md:py-12">
  <div class="mx-auto max-w-[72rem]">
    <div class="grid gap-6 sm:grid-cols-2">
      {
        TILES.map((t, i) => (
          <article
            class="rise flex flex-col rounded-lg border border-line/70 bg-surface p-6 md:p-8"
            style={`animation-delay: ${i * 80}ms`}
          >
            <h2 class="font-display text-xl font-bold leading-[1.25] tracking-[-0.01em] text-ink md:text-2xl">
              {t.title}
            </h2>
            <p class="mt-4 text-[0.95rem] leading-[1.65] text-muted">
              {t.body}
            </p>
          </article>
        ))
      }
    </div>

    <a
      href="/science"
      class="rise mt-7 inline-flex items-center gap-2 font-button text-sm tracking-wide text-accent-700 transition-colors hover:text-accent-800"
      style="animation-delay: 360ms"
    >
      The science
      <svg
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        set:html={ARROW}
      />
    </a>
  </div>
</section>
