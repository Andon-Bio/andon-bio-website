---
// HOME hero — text left on the shared rail, unlabeled ring/wheel right. No labels
// on the wheel (Measure/Reveal/Predict is retired), no buttons.
// Voice: "tRNA" never appears on Home.
import Ring from "../Ring.astro";
---

<section
  class="relative overflow-hidden px-6 pt-12 pb-8 md:px-10 md:pt-16 md:pb-10"
>
  {/* atmospheric amber wash, grounded in the warm canvas */}
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10"
    style="background: radial-gradient(55% 50% at 78% 18%, oklch(0.78 0.105 85 / 0.16), transparent 70%);"
  >
  </div>

  <div
    class="mx-auto grid max-w-[72rem] items-center gap-12 lg:grid-cols-[1.05fr_0.95fr] lg:gap-16"
  >
    <div>
      <h1
        class="rise text-balance font-display text-3xl font-extrabold leading-[1.08] tracking-[-0.03em] text-ink md:text-5xl"
      >
        What if you could tell which protein sequences would express well and
        which would fail, before you ever set foot in the lab?
      </h1>
      <p
        class="rise mt-7 max-w-[34rem] text-lg leading-[1.7] text-muted md:text-xl"
        style="animation-delay: 120ms"
      >
        Today, every new protein design is tested blind: whether a sequence
        expresses, and how much, comes down to trial and error.
      </p>
    </div>

    {/* Hero artifact: the slowly rotating ring — unlabeled brand imagery */}
    <Ring />
  </div>
</section>
