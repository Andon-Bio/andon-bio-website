---
import { SITE } from "../../site";
import Button from "../Button.astro";

const CALLOUTS = [
  {
    label: "Measure",
    sub: "Charged tRNAs, read directly",
    pos: "left-[-7rem] top-[14%] items-end text-right",
  },
  {
    label: "Reveal",
    sub: "Translational bottlenecks",
    pos: "right-[-7.5rem] top-[46%] items-start text-left",
  },
  {
    label: "Predict",
    sub: "Better sequence design",
    pos: "bottom-[8%] left-[-5rem] items-end text-right",
  },
];
---

<section
  class="relative overflow-hidden px-6 pt-16 pb-20 md:px-10 md:pt-24 md:pb-28"
>
  {/* atmospheric amber wash, grounded in the warm canvas */}
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10"
    style="background: radial-gradient(60% 55% at 50% 8%, oklch(0.78 0.105 85 / 0.16), transparent 70%);"
  >
  </div>

  <div class="mx-auto max-w-[52rem] text-center">
    <h1
      class="rise text-balance font-display text-4xl font-extrabold leading-[1.04] tracking-[-0.03em] text-ink md:text-6xl"
    >
      Making translation measurable
    </h1>
    <p
      class="rise mx-auto mt-6 max-w-[36rem] text-lg leading-[1.6] text-muted md:text-xl"
      style="animation-delay: 120ms"
    >
      Andon measures charged tRNAs directly — revealing what limits protein
      expression and powering predictive sequence design.
    </p>
    <div
      class="rise mt-9 flex flex-wrap items-center justify-center gap-x-6 gap-y-3"
      style="animation-delay: 240ms"
    >
      <Button href={`mailto:${SITE.email}`} size="lg">Get early access</Button>
      <Button href="#how" variant="link" size="lg">See how it works</Button>
    </div>
  </div>

  {/* Hero artifact: the rotating tRNA ring with measurement callouts */}
  <div
    class="rise-scale relative mx-auto mt-16 flex max-w-[40rem] items-center justify-center md:mt-20"
    style="animation-delay: 300ms"
  >
    <img
      src="/andon_ring.svg"
      alt="The 20 amino acids arranged as a tRNA charging ring"
      width="416"
      height="416"
      class="andon-ring w-[18rem] md:w-[26rem]"
    />

    {/* Callouts — absolute around the ring on lg */}
    <div class="pointer-events-none absolute inset-0 hidden lg:block">
      {
        CALLOUTS.map((c) => (
          <div class={`absolute flex w-[10rem] flex-col ${c.pos}`}>
            <div class="mb-2 flex items-center gap-2">
              <span class="h-1.5 w-1.5 rounded-full bg-accent" />
              <span class="h-px w-10 bg-accent/50" />
            </div>
            <span class="font-display text-sm font-bold text-ink">{c.label}</span>
            <span class="mt-1 text-xs leading-snug text-muted">{c.sub}</span>
          </div>
        ))
      }
    </div>
  </div>

  {/* Callouts — stacked row below the ring on small screens */}
  <div class="mx-auto mt-12 grid max-w-[34rem] grid-cols-3 gap-4 lg:hidden">
    {
      CALLOUTS.map((c) => (
        <div class="flex flex-col items-center text-center">
          <span class="mb-2 h-1.5 w-1.5 rounded-full bg-accent" />
          <span class="font-display text-sm font-bold text-ink">{c.label}</span>
          <span class="mt-1 text-xs leading-snug text-muted">{c.sub}</span>
        </div>
      ))
    }
  </div>
</section>
