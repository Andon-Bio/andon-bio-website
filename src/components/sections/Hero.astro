---
import { SITE } from "../../site";
import Button from "../Button.astro";
---

<section class="relative overflow-hidden bg-cream">
  <!-- warm glow behind the headline -->
  <div
    class="pointer-events-none absolute inset-x-0 top-0 h-[460px]"
    style="background: radial-gradient(62% 120% at 50% 0%, var(--color-cream-deep), transparent 70%);"
    aria-hidden="true"
  >
  </div>

  <div class="relative mx-auto max-w-4xl px-6 pt-20 pb-12 text-center sm:pt-28">
    <h1 class="font-display text-5xl font-bold tracking-tight text-ink sm:text-6xl md:text-7xl">
      Making translation measurable
    </h1>
    <p class="mx-auto mt-6 max-w-xl text-lg leading-relaxed text-muted">
      Andon measures charged tRNAs directly — revealing what limits protein
      expression and powering predictive sequence design.
    </p>
    <div class="mt-9 flex flex-col items-center justify-center gap-5 sm:flex-row sm:gap-8">
      <Button href={`mailto:${SITE.email}`} variant="pill">Get early access</Button>
      <Button href="/#how-it-works" variant="link">See how it works</Button>
    </div>
  </div>

  <!-- ring + Measure / Reveal / Predict callouts -->
  <div class="relative mx-auto max-w-5xl px-6 pb-24">
    <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-[1fr_auto_1fr]">
      <!-- left callouts -->
      <div class="order-2 flex flex-row justify-center gap-12 lg:order-1 lg:flex-col lg:items-end lg:gap-24 lg:text-right">
        <div>
          <span class="flex items-center gap-2 lg:flex-row-reverse">
            <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
            <span class="h-px w-8 bg-accent/40"></span>
          </span>
          <p class="mt-2 text-sm font-semibold text-ink">Measure</p>
          <p class="text-xs leading-snug text-muted">Charged tRNAs, read directly</p>
        </div>
        <div>
          <span class="flex items-center gap-2 lg:flex-row-reverse">
            <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
            <span class="h-px w-8 bg-accent/40"></span>
          </span>
          <p class="mt-2 text-sm font-semibold text-ink">Predict</p>
          <p class="text-xs leading-snug text-muted">Better sequence design</p>
        </div>
      </div>

      <!-- ring -->
      <div class="order-1 flex justify-center lg:order-2">
        <img
          src="/ptarmigan_ring.svg"
          alt="A ring of the 20 amino acids, representing direct measurement of charged tRNAs"
          width="460"
          height="460"
          class="andon-ring w-full max-w-[340px] sm:max-w-md"
        />
      </div>

      <!-- right callout -->
      <div class="order-3 flex justify-center lg:justify-start lg:text-left">
        <div>
          <span class="flex items-center gap-2">
            <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
            <span class="h-px w-8 bg-accent/40"></span>
          </span>
          <p class="mt-2 text-sm font-semibold text-ink">Reveal</p>
          <p class="text-xs leading-snug text-muted">Translational bottlenecks</p>
        </div>
      </div>
    </div>
  </div>
</section>
