---
interface Props {
  eyebrow: string;
  title: string;
  lead?: string;
}

const { eyebrow, title, lead } = Astro.props;
---

<section class="relative overflow-hidden bg-cream">
  <div
    class="pointer-events-none absolute inset-x-0 top-0 h-[420px]"
    style="background: radial-gradient(62% 120% at 50% 0%, var(--color-cream-deep), transparent 70%);"
    aria-hidden="true"
  >
  </div>
  <div class="relative mx-auto max-w-3xl px-6 pt-20 pb-14 text-center sm:pt-28">
    <p class="font-mono text-xs uppercase tracking-[0.18em] text-faint">
      {eyebrow}
    </p>
    <h1 class="mt-4 font-display text-4xl font-bold tracking-tight text-ink sm:text-5xl md:text-6xl">
      {title}
    </h1>
    {
      lead && (
        <p class="mx-auto mt-5 max-w-xl text-lg leading-relaxed text-muted">
          {lead}
        </p>
      )
    }
  </div>
</section>
