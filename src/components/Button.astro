---
interface Props {
  href: string;
  variant?: "pill" | "pill-light" | "link";
  class?: string;
}

const { href, variant = "pill", class: className = "" } = Astro.props;

const base =
  "inline-flex items-center gap-2 font-mono text-sm tracking-[0.035em] transition-colors duration-200";

const variants: Record<string, string> = {
  pill: "rounded-full bg-ink px-6 py-3 text-paper hover:bg-navy",
  "pill-light": "rounded-full border border-line bg-cream px-6 py-3 text-ink hover:border-ink",
  link: "text-accent hover:text-ink underline-offset-4 hover:underline",
};
---

<a href={href} class={`${base} ${variants[variant]} ${className}`}>
  <slot />
</a>
