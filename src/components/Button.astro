---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"a"> {
  variant?: "primary" | "secondary" | "amber" | "link";
  size?: "sm" | "default" | "lg";
}

const {
  variant = "primary",
  size = "default",
  class: className,
  ...rest
} = Astro.props;

const base =
  "font-button inline-flex items-center justify-center gap-2 rounded-full whitespace-nowrap transition-colors duration-200";

const variants: Record<string, string> = {
  primary: "bg-ink text-paper hover:bg-navy-soft",
  secondary: "border border-ink/25 text-ink hover:border-ink/60",
  amber: "bg-accent text-ink hover:bg-accent-600",
  link: "px-0 text-accent-700 underline-offset-4 hover:text-accent-800 hover:underline",
};

const sizes: Record<string, string> = {
  sm: "text-sm tracking-wide px-4 py-2",
  default: "text-sm tracking-wide px-6 py-3",
  lg: "text-base tracking-wide px-7 py-3.5",
};

// The link variant is inline text — keep the size's type scale, drop the padding.
const linkSizes: Record<string, string> = {
  sm: "text-sm tracking-wide",
  default: "text-sm tracking-wide",
  lg: "text-base tracking-wide",
};

// Non-link buttons get a 44px min height on touch devices (WCAG 2.5.5 tap
// target). pointer-coarse keeps desktop/mouse sizing exactly as designed.
const sizeClass =
  variant === "link" ? linkSizes[size] : `${sizes[size]} pointer-coarse:min-h-11`;
---

<a class:list={[base, variants[variant], sizeClass, className]} {...rest}>
  <slot />
</a>
