---
import { SITE, NAV } from "../site";

// Build-time dynamic year — never goes stale.
const year = new Date().getFullYear();
---

<footer class="border-t border-line-dark bg-navy px-6 py-14 text-paper md:px-10">
  <div
    class="mx-auto flex max-w-[72rem] flex-col gap-10 md:flex-row md:items-start md:justify-between"
  >
    <div class="max-w-[22rem]">
      <div class="flex items-center gap-3">
        <img src="/andon_ring_mono.svg" alt="" width="40" height="40" class="h-10 w-10" />
        <span class="font-display text-lg font-bold tracking-tight">Andon Bio</span>
      </div>
      <p class="mt-4 text-sm leading-[1.6] text-paper-muted">{SITE.tagline}</p>
      <a
        href={SITE.linkedin}
        target="_blank"
        rel="noopener"
        aria-label="Andon Bio on LinkedIn"
        class="mt-5 inline-flex text-paper-muted transition-colors hover:text-accent"
      >
        <svg
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"
          ></path>
        </svg>
      </a>
    </div>

    {/* Persistent site nav — also the only way to reach Science/About on mobile,
        where the header links are hidden. */}
    <nav
      class="flex flex-col gap-2 text-sm text-paper-muted"
      aria-label="Footer"
    >
      {
        NAV.map((item) => (
          <a
            href={item.href}
            class="transition-colors hover:text-paper"
          >
            {item.label}
          </a>
        ))
      }
      <a href={`mailto:${SITE.email}`} class="transition-colors hover:text-paper">
        Contact
      </a>
    </nav>

    <div
      class="flex flex-col gap-2 text-sm text-paper-muted md:items-end md:text-right"
    >
      <a
        href={`mailto:${SITE.email}`}
        class="text-accent transition-colors hover:text-accent-400"
      >
        {SITE.email}
      </a>
      <span>Aurora, Colorado</span>
      <span class="mt-2">© {year} Andon Bio. All rights reserved.</span>
    </div>
  </div>
</footer>
