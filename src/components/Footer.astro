---
import { SITE, NAV } from "../site";

// Build-time dynamic year — never goes stale.
const year = new Date().getFullYear();
---

<footer class="border-t border-line-dark bg-navy px-6 py-14 text-paper md:px-10">
  <div
    class="mx-auto flex max-w-[78rem] flex-col gap-10 md:flex-row md:items-start md:justify-between"
  >
    <div class="max-w-[22rem]">
      <div class="flex items-center gap-3">
        <img src="/andon_ring_mono.svg" alt="" width="40" height="40" class="h-10 w-10" />
        <span class="font-display text-lg font-bold tracking-tight">Andon Bio</span>
      </div>
      <p class="mt-4 text-sm leading-[1.6] text-paper-muted">{SITE.tagline}</p>
    </div>

    {/* Persistent site nav — also the only way to reach Science/About on mobile,
        where the header links are hidden. */}
    <nav
      class="flex flex-col gap-2 text-sm text-paper-muted"
      aria-label="Footer"
    >
      {
        NAV.map((item) => (
          <a
            href={item.href}
            class="transition-colors hover:text-paper"
          >
            {item.label}
          </a>
        ))
      }
      <a href={`mailto:${SITE.email}`} class="transition-colors hover:text-paper">
        Contact
      </a>
    </nav>

    <div
      class="flex flex-col gap-2 text-sm text-paper-muted md:items-end md:text-right"
    >
      <a
        href={`mailto:${SITE.email}`}
        class="text-accent transition-colors hover:text-accent-400"
      >
        {SITE.email}
      </a>
      <span>Aurora, Colorado</span>
      <span class="mt-2">© {year} Andon Bio. All rights reserved.</span>
    </div>
  </div>
</footer>
