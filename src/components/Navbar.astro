---
import { SITE, NAV } from "../site";
import Button from "./Button.astro";
---

<header
  class="sticky top-0 z-50 border-b border-line/60 bg-cream px-6 md:px-10"
>
  <div
    class="mx-auto flex w-full max-w-[72rem] items-center justify-between py-4"
  >
    <a href="/" class="flex items-center gap-3">
      <img
        src="/andon_ring.svg"
        alt=""
        width="36"
        height="36"
        class="h-8 w-8 transition-transform duration-700 hover:rotate-180 md:h-9 md:w-9"
      />
      <span
        class="font-display text-lg font-bold tracking-tight text-ink md:text-xl"
      >
        Andon Bio
      </span>
    </a>
    <nav class="flex items-center gap-6" aria-label="Primary">
      {
        NAV.map((item) => (
          <a
            href={item.href}
            class="hidden text-sm text-muted transition-colors hover:text-ink sm:inline"
          >
            {item.label}
          </a>
        ))
      }
      <Button href={`mailto:${SITE.email}`} size="sm">Contact</Button>
    </nav>
  </div>
</header>
