---
import Layout from "../layouts/Layout.astro";
import Cta from "../components/sections/Cta.astro";
import Button from "../components/Button.astro";
import { SITE } from "../site";

const ic = {
  microscope: `<path d="M6 18h8"/><path d="M3 22h18"/><path d="M14 22a7 7 0 1 0 0-14h-1"/><path d="M9 14h2"/><path d="M9 12a2 2 0 0 1-2-2V6h6v4a2 2 0 0 1-2 2Z"/><path d="M12 6V3a1 1 0 0 0-1-1H9a1 1 0 0 0-1 1v3"/>`,
  scan: `<path d="M3 7V5a2 2 0 0 1 2-2h2"/><path d="M17 3h2a2 2 0 0 1 2 2v2"/><path d="M21 17v2a2 2 0 0 1-2 2h-2"/><path d="M7 21H5a2 2 0 0 1-2-2v-2"/><circle cx="12" cy="12" r="3"/><path d="m16 16-1.9-1.9"/>`,
  sparkles: `<path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/><path d="M20 3v4"/><path d="M22 5h-4"/><path d="M4 17v2"/><path d="M5 18H3"/>`,
  dna: `<path d="m10 16 1.5 1.5"/><path d="m14 8-1.5-1.5"/><path d="M15 2c-1.798 1.998-2.518 3.995-2.807 5.993"/><path d="m16.5 10.5 1 1"/><path d="m17 6-2.891-2.891"/><path d="M2 15c6.667-6 13.333 0 20-6"/><path d="m20 9 .891.891"/><path d="M3.109 14.109 4 15"/><path d="m6.5 12.5 1 1"/><path d="m7 18-2.891-2.891"/><path d="M9 22c1.798-1.998 2.518-3.995 2.807-5.993"/>`,
  gauge: `<path d="m12 14 4-4"/><path d="M3.34 19a10 10 0 1 1 17.32 0"/>`,
  flask: `<path d="M14 2v6a2 2 0 0 0 .245.96l5.51 10.08A2 2 0 0 1 18 22H6a2 2 0 0 1-1.755-2.96l5.51-10.08A2 2 0 0 0 10 8V2"/><path d="M6.453 15h11.094"/><path d="M8.5 2h7"/>`,
};

const METHODS = [
  {
    icon: ic.microscope,
    kicker: "Measure",
    title: "Read tRNA charging directly",
    body: "aa-tRNA-seq is a single-molecule method built on Oxford Nanopore direct RNA sequencing. By chemically capturing the amino acid attached to each tRNA, we read whether a tRNA is charged — the molecular signal that tells you whether a cell actually has the resources to translate a given codon.",
  },
  {
    icon: ic.scan,
    kicker: "Reveal",
    title: "Find where supply fails demand",
    body: "Charging state, measured genome-wide, exposes translational bottlenecks: the specific codons where tRNA supply can't keep up with demand. Instead of inferring limits from yield alone, you see exactly which positions in a sequence starve the ribosome.",
  },
  {
    icon: ic.sparkles,
    kicker: "Predict",
    title: "Design sequences that express",
    body: "Those measurements feed a predictive engine that scores and redesigns coding sequences against real translational capacity — replacing trial-and-error codon optimization with data on what the host cell can actually produce.",
  },
];

const READOUTS = [
  { icon: ic.flask, label: "Charging state", detail: "Charged vs. uncharged, per tRNA, at single-molecule resolution." },
  { icon: ic.dna, label: "Sequence & modifications", detail: "tRNA identity and RNA modifications resolved from the same read." },
  { icon: ic.sparkles, label: "Amino-acid identity", detail: "ML models on raw nanopore signal infer the attached amino acid." },
  { icon: ic.gauge, label: "Supply vs. demand", detail: "Functional tRNA availability mapped against codon usage." },
];
---

<Layout
  title="The science"
  description="How Andon measures tRNA charging with single-molecule aa-tRNA-seq to reveal translational bottlenecks and predict better-expressing sequences."
>
  {/* Hero — text-led */}
  <section class="px-6 pt-20 pb-16 md:px-10 md:pt-28 md:pb-20">
    <div class="mx-auto max-w-[44rem]">
      <h1
        class="rise text-balance font-display text-4xl font-extrabold leading-[1.05] tracking-[-0.03em] text-ink md:text-[3.5rem]"
      >
        The measurement layer for protein expression
      </h1>
      <p
        class="rise mt-6 max-w-[38rem] text-lg leading-[1.7] text-muted md:text-xl"
        style="animation-delay: 120ms"
      >
        Protein output is limited by translation — yet the supply and demand of
        charged tRNAs has never been directly measurable. Andon makes it visible,
        then turns it into predictive design.
      </p>
      <div
        class="rise mt-10 h-px w-24 bg-accent"
        style="animation-delay: 220ms"
      >
      </div>
    </div>
  </section>

  {/* Method blocks — alternating editorial layout */}
  <section class="px-6 pb-8 md:px-10">
    <div class="mx-auto flex max-w-[72rem] flex-col gap-16 md:gap-24">
      {
        METHODS.map((m, i) => (
          <article
            class={`grid items-center gap-8 md:grid-cols-2 md:gap-16 ${i % 2 === 1 ? "md:[&>*:first-child]:order-2" : ""}`}
          >
            <div>
              <span class="font-button text-xs uppercase tracking-[0.18em] text-accent-700">
                {m.kicker}
              </span>
              <h2 class="mt-3 text-balance font-display text-2xl font-bold leading-[1.15] tracking-[-0.02em] text-ink md:text-3xl">
                {m.title}
              </h2>
              <p class="mt-4 max-w-[34rem] text-lg leading-[1.7] text-muted">
                {m.body}
              </p>
            </div>
            <div class="flex items-center justify-center">
              <div class="flex aspect-[4/3] w-full items-center justify-center rounded-2xl border border-line/70 bg-surface">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" class="text-accent-700" aria-hidden="true" set:html={m.icon} />
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  {/* Dark readout panel */}
  <section
    class="mt-20 bg-navy px-6 py-20 text-paper md:mt-28 md:px-10 md:py-28"
  >
    <div class="mx-auto max-w-[72rem]">
      <h2
        class="max-w-[36rem] text-balance font-display text-3xl font-bold leading-[1.1] tracking-[-0.02em] md:text-[2.5rem]"
      >
        What we read from a single molecule
      </h2>
      <p class="mt-4 max-w-[34rem] text-lg leading-[1.7] text-paper-muted">
        One nanopore read carries more than a sequence. aa-tRNA-seq resolves the
        full functional picture of translation at once.
      </p>
      <div
        class="mt-12 grid gap-px overflow-hidden rounded-2xl border border-line-dark bg-line-dark sm:grid-cols-2"
      >
        {
          READOUTS.map((r) => (
            <div class="flex gap-4 bg-navy p-7">
              <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl border border-line-dark bg-navy-soft text-accent">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={r.icon} />
              </span>
              <div>
                <h3 class="font-display text-lg font-bold tracking-tight">
                  {r.label}
                </h3>
                <p class="mt-1.5 text-[0.95rem] leading-[1.6] text-paper-muted">
                  {r.detail}
                </p>
              </div>
            </div>
          ))
        }
      </div>
      <div class="mt-8 text-sm text-paper-muted">
        aa-tRNA-seq was co-invented in the Hesselberth Lab at the University of
        Colorado Anschutz Medical Campus.
      </div>
      <div class="mt-8">
        <Button href={`mailto:${SITE.email}`} variant="amber" size="lg">
          Talk to the team
        </Button>
      </div>
    </div>
  </section>

  <Cta
    heading="Bring measurement to your expression work"
    body="We're partnering with protein engineers and biomanufacturers who want direct data on translation. Reach out for early access."
  />
</Layout>
