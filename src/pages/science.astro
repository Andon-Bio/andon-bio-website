---
import { Picture } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import Ring from "../components/Ring.astro";
import Trna from "../components/Trna.astro";
import Button from "../components/Button.astro";
import { PAPER, LINKS } from "../site";
import paperCover from "../assets/figures/paper-natcomms.jpg";
import talkThumb from "../assets/figures/london-calling-thumb.jpg";

const ARROW = `<path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>`;
---

<Layout
  title="The science"
  description="Every protein draws on a supply of charged tRNAs. Andon measures that supply directly — single-molecule, published in Nature Communications, and validated from bacteria to mammalian cells."
>
  {/* Hero — text left on the rail, rotating ring right. Absorbs the mechanism. */}
  <section class="px-6 pt-12 pb-8 md:px-10 md:pt-16 md:pb-10">
    <div
      class="mx-auto grid max-w-[72rem] items-center gap-12 lg:grid-cols-[1.05fr_0.95fr] lg:gap-16"
    >
      <div>
        <h1
          class="rise max-w-[44rem] text-balance font-display text-4xl font-extrabold leading-[1.05] tracking-[-0.03em] text-ink md:text-[3.5rem]"
        >
          The supply chain behind every protein.
        </h1>
        <p
          class="rise mt-6 max-w-[44rem] text-lg leading-[1.7] text-muted md:text-xl"
          style="animation-delay: 120ms"
        >
          Every protein draws on a supply of charged tRNAs: the molecules that
          carry amino acids to the ribosome. Production moves only as fast as the
          right ones arrive.
        </p>
        <div class="rise mt-8 h-px w-24 bg-accent" style="animation-delay: 220ms">
        </div>
      </div>
      <Ring />
    </div>
  </section>

  {/* The chemistry — text on the rail, the charging tRNA to its right,
      mirroring the hero's text/ring split. */}
  <section class="px-6 py-8 md:px-10 md:py-12">
    <div
      class="mx-auto grid max-w-[72rem] items-center gap-12 lg:grid-cols-[1.05fr_0.95fr] lg:gap-16"
    >
      <div>
        <span
          class="font-button text-xs uppercase tracking-[0.18em] text-accent-700"
        >
          The chemistry
        </span>
        <h2
          class="mt-3 max-w-[42rem] text-balance font-display text-3xl font-bold leading-[1.1] tracking-[-0.02em] text-ink md:text-[2.5rem]"
        >
          We keep the signal other methods throw away.
        </h2>
        <p class="mt-6 max-w-[46rem] text-lg leading-[1.7] text-muted">
          A charged tRNA carries its amino acid; an empty one doesn't. That
          amino acid — what the tRNA adds to a growing protein — is easily lost:
          it falls off on its own, or standard prep strips it away. Our
          chemistry holds it in place, so every tRNA is read individually by
          nanopore with its charge intact. One read gives us its sequence, its
          modifications, and the amino acid it carries.
        </p>
      </div>
      <Trna />
    </div>
  </section>

  {/* The method — evidence hub: published paper + recorded talk. */}
  <section class="px-6 py-8 md:px-10 md:py-12">
    <div class="mx-auto max-w-[72rem]">
      <span
        class="font-button text-xs uppercase tracking-[0.18em] text-accent-700"
      >
        The method
      </span>
      <h2
        class="mt-3 max-w-[42rem] text-balance font-display text-3xl font-bold leading-[1.1] tracking-[-0.02em] text-ink md:text-[2.5rem]"
      >
        Published and patent-pending.
      </h2>
      <p class="mt-6 max-w-[46rem] text-lg leading-[1.7] text-muted">
        Now validated from microbial to mammalian systems.
      </p>

      <article
        class="mt-8 overflow-hidden rounded-2xl border border-line/70 bg-surface"
      >
        <div class="flex flex-col gap-7 p-6 sm:flex-row sm:gap-8 md:p-8">
          <a
            href={PAPER.url}
            target="_blank"
            rel="noopener"
            class="group shrink-0 self-start"
            aria-label="Read the paper — opens the article in Nature Communications"
          >
            <Picture
              src={paperCover}
              alt="First page of the paper in Nature Communications"
              widths={[176, 352]}
              sizes="(min-width: 640px) 176px, 144px"
              formats={["avif", "webp"]}
              quality={72}
              loading="lazy"
              class="w-36 rounded-lg border border-line/70 shadow-sm transition-transform duration-200 group-hover:-translate-y-0.5 sm:w-44"
            />
          </a>
          <div>
            <h3
              class="font-display text-xl font-bold leading-[1.25] tracking-[-0.01em] text-ink md:text-2xl"
            >
              {PAPER.title}
            </h3>
            <p class="mt-4 text-[0.95rem] leading-[1.65] text-muted">
              {PAPER.authors}
              <span class="mt-1 block text-muted"
                >{PAPER.citation} Open access.</span
              >
            </p>
            <div class="mt-6">
              <Button
                href={PAPER.url}
                variant="secondary"
                size="default"
                target="_blank"
                rel="noopener"
              >
                Read the paper
              </Button>
            </div>
          </div>
        </div>
      </article>
    </div>
  </section>

  {/* The method, presented at London Calling — dark close, the talk. */}
  <section
    class="bg-navy px-6 pt-12 pb-10 text-paper md:px-10 md:pt-16 md:pb-12"
  >
    <div class="mx-auto max-w-[72rem]">
      <a
        href={LINKS.londonCallingWatch}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 font-button text-sm tracking-wide text-accent transition-colors hover:text-accent-400"
      >
        The method, presented at London Calling
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          set:html={ARROW}
        />
      </a>
      {/* Click-to-load facade: a static poster stands in until the visitor
          clicks, so YouTube's player JS + cookies never load otherwise. */}
      <div
        class="mt-5 aspect-video w-full max-w-[60rem] overflow-hidden rounded-2xl border border-line-dark bg-navy-soft"
      >
        <button
          type="button"
          class="yt-facade group relative block h-full w-full cursor-pointer"
          data-embed={`${LINKS.londonCallingEmbed}?autoplay=1`}
          aria-label="Play the talk: The method, presented at London Calling"
        >
          <Picture
            src={talkThumb}
            alt=""
            formats={["avif", "webp"]}
            widths={[640, 960, 1280]}
            sizes="(min-width: 64rem) 60rem, 100vw"
            quality={70}
            loading="lazy"
            class="h-full w-full object-cover"
          />
          <span
            class="absolute inset-0 grid place-items-center bg-navy/40 transition-colors group-hover:bg-navy/25"
            aria-hidden="true"
          >
            <span
              class="grid h-16 w-16 place-items-center rounded-full bg-ink/85 shadow-lg ring-1 ring-white/10 transition-transform group-hover:scale-105"
            >
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="currentColor"
                class="ml-0.5 text-paper"
              >
                <path d="M8 5v14l11-7z"></path>
              </svg>
            </span>
          </span>
        </button>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Click-to-load YouTube facade — swaps the poster for the real embed only on
  // click, so the heavy player never loads for visitors who don't watch. Astro
  // bundles this script into /science only; the rest of the site stays zero-JS.
  for (const btn of document.querySelectorAll(".yt-facade")) {
    btn.addEventListener("click", () => {
      const iframe = document.createElement("iframe");
      iframe.className = "h-full w-full";
      iframe.src = btn.dataset.embed;
      iframe.title = "The method, presented at London Calling";
      iframe.allow =
        "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share";
      iframe.referrerPolicy = "strict-origin-when-cross-origin";
      iframe.allowFullscreen = true;
      btn.replaceWith(iframe);
      iframe.focus();
    });
  }
</script>
