---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
---

<Layout title="Page not found">
  <section class="bg-cream">
    <div class="mx-auto flex min-h-[60vh] max-w-xl flex-col items-center justify-center px-6 py-24 text-center">
      <p class="font-button text-xs uppercase tracking-[0.18em] text-accent-700">404</p>
      <h1 class="mt-4 font-display text-4xl font-bold text-ink md:text-5xl">
        This page slipped the ribosome
      </h1>
      <p class="mt-4 text-lg leading-[1.7] text-muted">
        The page you're looking for doesn't exist or has moved.
      </p>
      <Button href="/" class="mt-8">Back to home</Button>
    </div>
  </section>
</Layout>
