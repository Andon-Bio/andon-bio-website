---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import SupportedBy from "../components/sections/SupportedBy.astro";
import { LINKS } from "../site";

// Team photos live in src/assets so astro:assets emits optimized, responsive WebP.
import lauraPhoto from "../assets/team/laura-white.jpg";
import jakePhoto from "../assets/team/jake-armstrong.jpg";
import jayPhoto from "../assets/team/jay-hesselberth.jpg";
import keziaPhoto from "../assets/team/kezia-dobson.jpg";
import aleksPhoto from "../assets/team/aleks-radakovic.jpg";
import spikePhoto from "../assets/team/spike-willcocks.jpg";

// One unified team grid — same tile size for everyone. The role label on each
// tile delineates founders from the founding scientist + advisor(s); we no longer
// split them into two sections. Founders first.
const TEAM = [
  {
    name: "Laura White, PhD",
    role: "CEO, Co-Founder",
    photo: lauraPhoto,
    bio: "Co-invented aa-tRNA-seq and led its development in the Hesselberth Lab. PhD in molecular biology. Strategy consultant turned tRNA biologist, working across experimental and computational method development.",
  },
  {
    name: "Jake Armstrong, MBA",
    role: "COO, Co-Founder",
    photo: jakePhoto,
    bio: "15+ years building and scaling SaaS and ML platforms (IBM, BryterCX). Leads product, commercial, and the ML platform.",
  },
  {
    name: "Jay Hesselberth, PhD",
    role: "Scientific Co-Founder",
    photo: jayPhoto,
    bio: "Co-invented aa-tRNA-seq. Professor at the University of Colorado School of Medicine and Director of the University of Colorado RNA Bioscience Initiative.",
  },
  {
    name: "Kezia Dobson",
    role: "Founding Scientist",
    photo: keziaPhoto,
    bio: "Joins from the Hesselberth Lab; leads wet lab operations and project execution. Optimized and validated the published aa-tRNA-seq method into commercial-grade SOPs.",
  },
  {
    name: "Aleksandar Radakovic, PhD",
    role: "Scientific Advisor",
    photo: aleksPhoto,
    bio: "Developed the covalent-capture chemistry behind aa-tRNA-seq during his PhD in Jack Szostak's lab. Helen Hay Whitney Fellow at the University of Chicago, investigating the origins of translation.",
  },
  {
    name: "Spike Willcocks, PhD",
    role: "Strategic Advisor",
    photo: spikePhoto,
    bio: "Co-founder, Oxford Nanopore Technologies.",
  },
];
---

<Layout
  title="About"
  description="Andon Bio is a University of Colorado School of Medicine spinout in Aurora, Colorado, building the measurement layer that makes protein expression predictable, starting with direct measurement of the cellular supply chain behind production."
>
  {/* Team — the About page opens straight into the team grid. */}
  <section class="px-6 pt-12 pb-8 md:px-10 md:pt-16 md:pb-12">
    <div class="mx-auto max-w-[72rem]">
      <h1
        class="rise font-display text-3xl font-bold leading-[1.1] tracking-[-0.02em] text-ink md:text-[2.5rem]"
      >
        Team
      </h1>
      <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          TEAM.map((p, i) => (
            <article
              class="rise flex h-full flex-col overflow-hidden rounded-2xl border border-line/70 bg-surface"
              style={`animation-delay: ${i * 60}ms`}
            >
              <Image
                src={p.photo}
                alt={p.name}
                widths={[368, 736]}
                sizes="(min-width: 1024px) 368px, (min-width: 640px) 45vw, 90vw"
                format="webp"
                quality={72}
                loading="lazy"
                class="aspect-square w-full object-cover object-top"
              />
              <div class="p-6">
                <h3 class="font-display text-xl font-bold tracking-tight text-ink">
                  {p.name}
                </h3>
                <p class="mt-1 font-button text-xs uppercase tracking-[0.14em] text-accent-700">
                  {p.role}
                </p>
                <p class="mt-4 text-[0.95rem] leading-[1.65] text-muted">
                  {p.bio}
                </p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  {/* Beat 3 — Colorado. Text left on the rail; state outline + Aurora star right. */}
  <section class="px-6 py-8 md:px-10 md:py-12">
    <div
      class="mx-auto grid max-w-[72rem] items-center gap-10 lg:grid-cols-[1fr_0.7fr] lg:gap-16"
    >
      <div>
        <h2
          class="max-w-[42rem] text-balance font-display text-3xl font-bold leading-[1.1] tracking-[-0.02em] text-ink md:text-[2.5rem]"
        >
          The front range of RNA science.
        </h2>
        <p class="mt-6 max-w-[46rem] text-lg leading-[1.75] text-muted">
          Andon Bio is a spinout of the <a
            href={LINKS.rbi}
            target="_blank"
            rel="noopener"
            class="text-accent-700 underline-offset-4 hover:text-accent-800 hover:underline"
            >RNA Bioscience Initiative</a
          > at the University of Colorado School of Medicine. Colorado boasts a
          robust, <a
            href={LINKS.rnaClub}
            target="_blank"
            rel="noopener"
            class="text-accent-700 underline-offset-4 hover:text-accent-800 hover:underline"
            >40-year-old RNA research ecosystem</a
          > — a self-replicating community translating foundational science into
          new discoveries.
        </p>
      </div>

      {/* Flag of Colorado — official public-domain state flag (SVG). Thin frame
          so the white stripe reads against the cream. */}
      <div class="flex justify-center lg:justify-end">
        <img
          src="/figures/colorado-flag.svg"
          alt="Flag of Colorado"
          width="1800"
          height="1200"
          loading="lazy"
          class="w-full max-w-[16rem] rounded-xl border border-line/70 shadow-sm"
        />
      </div>
    </div>
  </section>

  <SupportedBy />
</Layout>
