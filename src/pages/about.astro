---
import Layout from "../layouts/Layout.astro";
import SupportedBy from "../components/sections/SupportedBy.astro";
import Cta from "../components/sections/Cta.astro";
import { LINKS } from "../site";

// Spike Willcocks (ONT co-founder) is staged but GATED until his advisory
// agreement is signed. Flip to true to ship his card — nothing else to change.
const SHOW_SPIKE = false;

// One unified team grid — same tile size for everyone. The role label on each
// tile delineates founders from the founding scientist + advisor(s); we no longer
// split them into two sections. Founders first.
const TEAM = [
  {
    name: "Laura White, PhD",
    role: "CEO, Co-Founder, Co-Inventor",
    photo: "/team/laura-white.jpg",
    bio: "Co-invented aa-tRNA-seq and led its development in the Hesselberth Lab. PhD in Molecular Biology. Strategy consultant turned tRNA biologist; experimental and computational methods development.",
  },
  {
    name: "Jake Armstrong, MBA",
    role: "COO, Co-Founder",
    photo: "/team/jake-armstrong.jpg",
    bio: "15+ years building and scaling SaaS and ML platforms (IBM, BryterCX). Leads product, commercial, and the ML platform.",
  },
  {
    name: "Jay Hesselberth, PhD",
    role: "Scientific Co-Founder, Co-Inventor",
    photo: "/team/jay-hesselberth.jpg",
    bio: "Professor at the University of Colorado School of Medicine and Director of the CU RNA Bioscience Initiative. Co-invented aa-tRNA-seq.",
  },
  {
    name: "Kezia Dobson",
    role: "Founding Scientist",
    photo: "/team/kezia-dobson.jpg",
    bio: "Leads platform R&D and wet-lab build-out. Joins from the Hesselberth Lab.",
  },
  {
    name: "Aleksandar Radakovic, PhD",
    role: "Co-Inventor, Scientific Advisor",
    photo: "/team/aleks-radakovic.jpg",
    bio: "Helen Hay Whitney Fellow in the Thornton Lab at the University of Chicago.",
  },
  ...(SHOW_SPIKE
    ? [
        {
          name: "Spike Willcocks, PhD",
          role: "Scientific Advisor",
          photo: "/team/spike-willcocks.jpg",
          bio: "Co-founder, Oxford Nanopore Technologies.",
        },
      ]
    : []),
];
---

<Layout
  title="About"
  description="Andon Bio is a University of Colorado School of Medicine spinout in Aurora, Colorado, building the measurement layer that makes protein expression predictable — starting with direct measurement of the cellular supply chain behind production."
>
  {/* Hero */}
  <section class="px-6 pt-20 pb-16 md:px-10 md:pt-28 md:pb-20">
    <div class="mx-auto max-w-[48rem]">
      <h1
        class="rise text-balance font-display text-4xl font-extrabold leading-[1.05] tracking-[-0.03em] text-ink md:text-[3.5rem]"
      >
        We're building the measurement layer for protein production.
      </h1>
      <p
        class="rise mt-6 max-w-[42rem] text-lg leading-[1.7] text-muted md:text-xl"
        style="animation-delay: 120ms"
      >
        Andon Bio turns a part of the cell that has never been visible into data,
        and that data into a way to predict how proteins express. We started with
        a method no one else had. We're building it into the foundation that
        protein design has been missing.
      </p>
    </div>
  </section>

  {/* Beat 1 — thesis / data frontier */}
  <section class="border-t border-line/60 px-6 py-20 md:px-10 md:py-24">
    <div
      class="mx-auto grid max-w-[72rem] gap-10 md:grid-cols-[1.1fr_1fr] md:gap-16"
    >
      <h2
        class="rise text-balance font-display text-2xl font-bold leading-[1.15] tracking-[-0.02em] text-ink md:text-[2.25rem]"
      >
        A new kind of biological data.
      </h2>
      <div
        class="rise space-y-4 self-end text-lg leading-[1.7] text-muted"
        style="animation-delay: 100ms"
      >
        <p>
          For all the progress in designing proteins, one question stays
          stubbornly empirical: will a given sequence actually express, and how
          well? The answer depends on a layer of cell biology that no instrument
          could measure, until now.
        </p>
        <p>
          Andon reads it directly, which means it can be measured at scale, across
          proteins and systems, for the first time. That's a new category of data,
          the kind that models get built on. We think it's the missing input for
          predicting expression, and we're generating it.
        </p>
      </div>
    </div>
  </section>

  {/* Beat 2 — Team. One uniform grid; the role label on each tile delineates. */}
  <section class="px-6 py-12 md:px-10 md:py-16">
    <div class="mx-auto max-w-[72rem]">
      <h2
        class="font-display text-2xl font-bold tracking-[-0.02em] text-ink md:text-3xl"
      >
        Team
      </h2>
      <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          TEAM.map((p, i) => (
            <article
              class="rise flex h-full flex-col overflow-hidden rounded-2xl border border-line/70 bg-surface"
              style={`animation-delay: ${i * 60}ms`}
            >
              <img
                src={p.photo}
                alt={p.name}
                width="800"
                height="800"
                loading="lazy"
                class="aspect-square w-full object-cover object-top"
              />
              <div class="p-6">
                <h3 class="font-display text-xl font-bold tracking-tight text-ink">
                  {p.name}
                </h3>
                <p class="mt-1 font-button text-xs uppercase tracking-[0.14em] text-accent-700">
                  {p.role}
                </p>
                <p class="mt-4 text-[0.95rem] leading-[1.65] text-muted">
                  {p.bio}
                </p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  {/* Beat 3 — Colorado */}
  <section class="px-6 pt-12 pb-4 md:px-10 md:pt-16">
    <div class="mx-auto max-w-[72rem]">
      <h2
        class="font-display text-2xl font-bold tracking-[-0.02em] text-ink md:text-3xl"
      >
        The front range of RNA science.
      </h2>
      <p class="mt-5 max-w-[46rem] text-lg leading-[1.7] text-muted">
        Andon Bio is a spinout of the <a
          href={LINKS.rbi}
          target="_blank"
          rel="noopener"
          class="text-accent-700 underline-offset-4 hover:text-accent-800 hover:underline"
          >RNA Bioscience Initiative</a
        > at the University of Colorado. Colorado boasts a robust, <a
          href={LINKS.rnaClub}
          target="_blank"
          rel="noopener"
          class="text-accent-700 underline-offset-4 hover:text-accent-800 hover:underline"
          >40-year RNA research ecosystem</a
        > — a self-replicating community translating foundational science into new
        discoveries.
      </p>
    </div>
  </section>

  <div class="mt-10 md:mt-14">
    <SupportedBy />
  </div>

  <Cta
    heading="Build with us."
    body="Whether you express a lot of protein, build the models that will use this data, or want to back what we're building — we'd like to hear from you."
    cta="Let's talk"
  />
</Layout>
